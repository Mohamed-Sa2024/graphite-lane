# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# --- GitHub OAuth App ---
# Create at https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# --- Data mode ---
# When AUTH_GITHUB_ID is empty OR this is "true", the app serves built-in
# fixtures so you can explore the UI without configuring OAuth.
# Set to "false" once OAuth is configured to use live GitHub data.
MOCK_DATA=
